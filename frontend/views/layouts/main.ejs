<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= appName %> | <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Private DeFi Lending' %></title>
  <link rel="icon" type="image/png" href="/img/fhield-icon.png" />
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/effects.css" />
  <%- include('../partials/tailwind-config') %>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.umd.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body class="font-body selection:bg-primary/30 selection:text-primary bg-background text-on-background<%= typeof useSidebar !== 'undefined' && useSidebar ? '' : ' min-h-screen flex flex-col' %>">
  <%- include('../partials/navbar', { activePage: activePage }) %>
  <% if (typeof useSidebar !== 'undefined' && useSidebar) { %>
    <%- include('../partials/sidebar', { activePage: activePage }) %>
  <% } %>

  <%- body %>

  <% if (typeof useSidebar === 'undefined' || !useSidebar) { %>
    <%- include('../partials/footer') %>
  <% } %>

  <% if (typeof useSidebar !== 'undefined' && useSidebar) { %>
    <%- include('../partials/mobile-nav', { activePage: activePage }) %>
  <% } %>

  <div id="wallet-connect-modal" class="fixed inset-0 z-[200] hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-wallet-modal-backdrop></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="glass-panel w-full max-w-md rounded-2xl border border-outline-variant/10 relative">
        <div class="flex justify-between items-center p-6 pb-4">
          <h3 class="font-headline font-bold text-xl text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">account_balance_wallet</span>
            Connect Wallet
          </h3>
          <button data-wallet-modal-close class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant hover:text-on-surface hover:bg-surface-container transition-colors">
            <span class="material-symbols-outlined text-xl">close</span>
          </button>
        </div>
        <div class="px-6 pb-2">
          <p class="text-sm text-on-surface-variant">Select a wallet to connect to FHIELD protocol.</p>
        </div>
        <div id="wallet-list" class="p-6 pt-4 space-y-3">
          <div class="text-center py-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 mb-3 block animate-spin">progress_activity</span>
            <p class="text-sm text-on-surface-variant">Detecting wallets...</p>
          </div>
        </div>
        <div class="px-6 pb-6">
          <div class="flex items-center gap-3 p-3 rounded-lg bg-tertiary/5 border border-tertiary/10">
            <span class="material-symbols-outlined text-tertiary text-sm" style="font-variation-settings: 'FILL' 1;">info</span>
            <p class="text-xs text-on-surface-variant leading-relaxed">Only browser-based Web3 wallet extensions are supported. Make sure your wallet is installed and active.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="module" src="/js/app.js"></script>
</body>
</html>
