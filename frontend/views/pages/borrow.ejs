<script type="application/json" id="position-data">
<%- JSON.stringify({ healthFactor: position.healthFactor, borrowingPowerUsed: position.borrowingPowerUsed, borrowingUsed: position.borrowingUsed, borrowingAvailable: position.borrowingAvailable, totalCollateralUSD: position.borrowingUsed + position.borrowingAvailable, liquidationThreshold: 0.85 }) %>
</script>
<script>
(function() {
  const POSITION = JSON.parse(document.getElementById('position-data').textContent);

  // --- Search ---
  const searchInput = document.getElementById('borrow-search');
  const rows = document.querySelectorAll('.borrow-row');
  const noResults = document.getElementById('borrow-no-results');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      let visible = 0;
      rows.forEach(row => {
        const asset = (row.dataset.asset || '').toLowerCase();
        const full = (row.dataset.fullname || '').toLowerCase();
        const match = !q || asset.includes(q) || full.includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });
  }

  // --- Sort ---
  document.querySelectorAll('#borrow-table th[data-sort]').forEach(th => {
    let asc = true;
    th.addEventListener('click', () => {
      const key = th.dataset.sort;
      const tbody = document.getElementById('borrow-body');
      const sorted = [...rows].sort((a, b) => {
        const va = parseFloat(a.dataset[camel(key)]) || 0;
        const vb = parseFloat(b.dataset[camel(key)]) || 0;
        return asc ? va - vb : vb - va;
      });
      sorted.forEach(r => tbody.appendChild(r));
      asc = !asc;
    });
  });

  function camel(s) {
    return s.replace(/-([a-z])/g, (_, c) => c.toUpperCase());
  }

  // --- Color logic for LTV/HF ---
  function ltvColor(pct) {
    if (pct >= 80) return 'text-red-400';
    if (pct >= 60) return 'text-amber-400';
    return 'text-on-surface';
  }
  function hfColor(val) {
    if (val <= 1.1) return 'text-red-400';
    if (val <= 1.5) return 'text-amber-400';
    return 'text-primary';
  }

  // --- Borrow Modal ---
  const borrowModal = document.getElementById('borrow-modal');
  let currentBorrowAsset = null;

  document.querySelectorAll('.borrow-open-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const row = btn.closest('tr');
      currentBorrowAsset = {
        name: row.dataset.asset,
        fullName: row.dataset.fullname,
        borrowAPY: parseFloat(row.dataset.borrowApy),
        available: parseFloat(row.dataset.available),
        availableFmt: row.dataset.availableFmt,
        utilization: row.dataset.utilization,
        img: row.dataset.img,
      };
      openBorrowModal(currentBorrowAsset);
    });
  });

  function openBorrowModal(asset) {
    document.getElementById('borrow-modal-asset-name').textContent = asset.name;
    document.getElementById('borrow-modal-asset-display').textContent = asset.name;
    document.getElementById('borrow-modal-asset-fullname').textContent = asset.fullName;
    document.getElementById('borrow-modal-asset-img').src = asset.img;
    document.getElementById('borrow-modal-available').textContent = asset.availableFmt;
    document.getElementById('borrow-modal-apy').textContent = asset.borrowAPY + '%';
    document.getElementById('borrow-modal-utilization').textContent = asset.utilization + '%';
    document.getElementById('borrow-modal-amount').value = '';
    updateBorrowPreview(0);
    borrowModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeBorrowModal() {
    borrowModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelector('[data-borrow-modal-backdrop]')?.addEventListener('click', closeBorrowModal);
  document.querySelector('[data-borrow-modal-close]')?.addEventListener('click', closeBorrowModal);

  document.getElementById('borrow-modal-amount')?.addEventListener('input', (e) => {
    const val = parseFloat(e.target.value) || 0;
    updateBorrowPreview(val);
  });

  document.getElementById('borrow-modal-max-btn')?.addEventListener('click', () => {
    if (!currentBorrowAsset) return;
    const maxVal = currentBorrowAsset.available;
    document.getElementById('borrow-modal-amount').value = maxVal;
    updateBorrowPreview(maxVal);
  });

  document.querySelectorAll('.borrow-pct-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!currentBorrowAsset) return;
      const pct = parseInt(btn.dataset.pct);
      const val = Math.floor(currentBorrowAsset.available * pct / 100);
      document.getElementById('borrow-modal-amount').value = val;
      updateBorrowPreview(val);
    });
  });

  function updateBorrowPreview(amount) {
    const apy = currentBorrowAsset ? currentBorrowAsset.borrowAPY : 0;
    const dailyRate = apy / 100 / 365;
    const hourlyRate = apy / 100 / 8760;
    const dailyInterest = amount * dailyRate;
    const hourlyInterest = amount * hourlyRate;
    const hasAmount = amount > 0;

    const usdEl = document.getElementById('borrow-modal-usd');
    if (usdEl) usdEl.textContent = hasAmount ? '≈ $' + amount.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '';

    const dailyEl = document.getElementById('borrow-modal-daily-interest');
    if (dailyEl) dailyEl.textContent = hasAmount ? '$' + dailyInterest.toFixed(4) + '/day' : '—';

    const hourlyEl = document.getElementById('borrow-modal-hourly-interest');
    if (hourlyEl) hourlyEl.textContent = hasAmount ? '$' + hourlyInterest.toFixed(6) + '/hr' : '—';

    ['borrow-modal-ltv', 'borrow-modal-hf'].forEach(p => {
      const arrowEl = document.getElementById(p + '-arrow');
      const newEl = document.getElementById(p + '-new');
      if (arrowEl) arrowEl.classList.toggle('hidden', !hasAmount);
      if (newEl) newEl.classList.toggle('hidden', !hasAmount);
    });

    if (hasAmount) {
      const newBorrowed = POSITION.borrowingUsed + amount;
      const totalCollateral = POSITION.totalCollateralUSD;
      const newLTV = totalCollateral > 0 ? (newBorrowed / totalCollateral * 100) : 0;
      const newHF = newBorrowed > 0 ? (totalCollateral * POSITION.liquidationThreshold / newBorrowed) : POSITION.healthFactor;

      const ltvNewEl = document.getElementById('borrow-modal-ltv-new');
      if (ltvNewEl) { ltvNewEl.textContent = newLTV.toFixed(1) + '%'; ltvNewEl.className = ltvColor(newLTV); }
      const hfNewEl = document.getElementById('borrow-modal-hf-new');
      if (hfNewEl) { hfNewEl.textContent = newHF.toFixed(2); hfNewEl.className = hfColor(newHF); }
    }
  }

  document.getElementById('borrow-modal-submit')?.addEventListener('click', async function() {
    const amount = document.getElementById('borrow-modal-amount').value;
    if (!amount || parseFloat(amount) <= 0 || !currentBorrowAsset) return;
    await executeTx(this, 'borrow', currentBorrowAsset.name, amount, closeBorrowModal);
  });

  // --- Manage Modal ---
  const manageModal = document.getElementById('manage-modal');
  let currentManageAsset = null;

  document.querySelectorAll('.borrow-manage-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const row = btn.closest('tr');
      currentManageAsset = {
        name: row.dataset.asset,
        fullName: row.dataset.fullname,
        borrowAPY: parseFloat(row.dataset.borrowApy),
        available: parseFloat(row.dataset.available),
        availableFmt: row.dataset.availableFmt,
        img: row.dataset.img,
      };
      openManageModal(currentManageAsset);
    });
  });

  function openManageModal(asset) {
    document.getElementById('manage-modal-asset-name').textContent = asset.name;
    document.getElementById('manage-modal-asset-display').textContent = asset.name;
    document.getElementById('manage-modal-asset-fullname').textContent = asset.fullName;
    document.getElementById('manage-modal-asset-img').src = asset.img;
    document.getElementById('manage-borrow-available').textContent = asset.availableFmt;
    const walletBal = window.fhield?.wallet?.getBalance(asset.name) || 0;
    document.getElementById('manage-repay-wallet').textContent = walletBal.toLocaleString() + ' ' + asset.name;
    document.getElementById('manage-borrow-amount').value = '';
    document.getElementById('manage-repay-amount').value = '';
    switchManageTab('borrow-more');
    manageModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeManageModal() {
    manageModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelector('[data-manage-modal-backdrop]')?.addEventListener('click', closeManageModal);
  document.querySelector('[data-manage-modal-close]')?.addEventListener('click', closeManageModal);

  function switchManageTab(tab) {
    document.querySelectorAll('.manage-tab').forEach(t => {
      const isActive = t.dataset.manageTab === tab;
      t.classList.toggle('bg-primary', isActive);
      t.classList.toggle('text-on-primary', isActive);
      t.classList.toggle('text-on-surface-variant', !isActive);
    });
    document.getElementById('manage-borrow-more-panel').classList.toggle('hidden', tab !== 'borrow-more');
    document.getElementById('manage-repay-panel').classList.toggle('hidden', tab !== 'repay');
  }

  document.querySelectorAll('.manage-tab').forEach(t => {
    t.addEventListener('click', () => switchManageTab(t.dataset.manageTab));
  });

  document.getElementById('manage-borrow-amount')?.addEventListener('input', (e) => {
    const val = parseFloat(e.target.value) || 0;
    updateManageBorrowPreview(val);
  });

  document.getElementById('manage-borrow-max-btn')?.addEventListener('click', () => {
    if (!currentManageAsset) return;
    document.getElementById('manage-borrow-amount').value = currentManageAsset.available;
    updateManageBorrowPreview(currentManageAsset.available);
  });

  function updateManageBorrowPreview(amount) {
    const hasAmount = amount > 0;
    ['manage-ltv', 'manage-hf'].forEach(p => {
      const arrowEl = document.getElementById(p + '-arrow');
      const newEl = document.getElementById(p + '-new');
      if (arrowEl) arrowEl.classList.toggle('hidden', !hasAmount);
      if (newEl) newEl.classList.toggle('hidden', !hasAmount);
    });

    if (hasAmount) {
      const newBorrowed = POSITION.borrowingUsed + amount;
      const total = POSITION.totalCollateralUSD;
      const newLTV = total > 0 ? (newBorrowed / total * 100) : 0;
      const newHF = newBorrowed > 0 ? (total * POSITION.liquidationThreshold / newBorrowed) : POSITION.healthFactor;

      const ltvEl = document.getElementById('manage-ltv-new');
      if (ltvEl) { ltvEl.textContent = newLTV.toFixed(1) + '%'; ltvEl.className = ltvColor(newLTV); }
      const hfEl = document.getElementById('manage-hf-new');
      if (hfEl) { hfEl.textContent = newHF.toFixed(2); hfEl.className = hfColor(newHF); }
    }
  }

  document.getElementById('manage-repay-amount')?.addEventListener('input', (e) => {
    const val = parseFloat(e.target.value) || 0;
    updateRepayPreview(val);
  });

  document.getElementById('manage-repay-max-btn')?.addEventListener('click', () => {
    const maxRepay = POSITION.borrowingUsed;
    document.getElementById('manage-repay-amount').value = maxRepay;
    updateRepayPreview(maxRepay);
  });

  function updateRepayPreview(amount) {
    const hasAmount = amount > 0;
    ['repay-ltv', 'repay-hf'].forEach(p => {
      const arrowEl = document.getElementById(p + '-arrow');
      const newEl = document.getElementById(p + '-new');
      if (arrowEl) arrowEl.classList.toggle('hidden', !hasAmount);
      if (newEl) newEl.classList.toggle('hidden', !hasAmount);
    });

    if (hasAmount) {
      const newBorrowed = Math.max(0, POSITION.borrowingUsed - amount);
      const total = POSITION.totalCollateralUSD;
      const newLTV = total > 0 ? (newBorrowed / total * 100) : 0;
      const newHF = newBorrowed > 0 ? (total * POSITION.liquidationThreshold / newBorrowed) : 99;

      const ltvEl = document.getElementById('repay-ltv-new');
      if (ltvEl) { ltvEl.textContent = newLTV.toFixed(1) + '%'; ltvEl.className = ltvColor(newLTV); }
      const hfEl = document.getElementById('repay-hf-new');
      if (hfEl) { hfEl.textContent = Math.min(newHF, 99).toFixed(2); hfEl.className = hfColor(newHF); }
    }
  }

  document.getElementById('manage-borrow-submit')?.addEventListener('click', async function() {
    const amount = document.getElementById('manage-borrow-amount').value;
    if (!amount || parseFloat(amount) <= 0 || !currentManageAsset) return;
    await executeTx(this, 'borrow', currentManageAsset.name, amount, closeManageModal);
  });

  document.getElementById('manage-repay-submit')?.addEventListener('click', async function() {
    const amount = document.getElementById('manage-repay-amount').value;
    if (!amount || parseFloat(amount) <= 0 || !currentManageAsset) return;
    await executeTx(this, 'repay', currentManageAsset.name, amount, closeManageModal);
  });

  // --- Collateral Modal ---
  const collateralModal = document.getElementById('collateral-modal');
  let collateralAction = 'add';
  let collateralAssetName = '';

  document.querySelectorAll('[data-collateral-action]').forEach(btn => {
    btn.addEventListener('click', () => {
      collateralAction = btn.dataset.collateralAction;
      collateralAssetName = btn.dataset.collateralName;
      openCollateralModal(collateralAction, collateralAssetName);
    });
  });

  function openCollateralModal(action, asset) {
    const isAdd = action === 'add';
    document.getElementById('collateral-modal-icon').textContent = isAdd ? 'add_circle' : 'remove_circle';
    document.getElementById('collateral-modal-title').textContent = isAdd ? 'Add Collateral' : 'Withdraw Collateral';
    document.getElementById('collateral-modal-asset-name').textContent = asset;
    document.getElementById('collateral-modal-label').textContent = isAdd ? 'Amount to Add' : 'Amount to Withdraw';
    document.getElementById('collateral-modal-submit-text').innerHTML = isAdd ? 'Encrypt &amp; Add Collateral' : 'Encrypt &amp; Withdraw';
    const balance = isAdd ? (window.fhield?.wallet?.getBalance(asset) || 0) : 0;
    document.getElementById('collateral-modal-balance').textContent = isAdd ? balance.toLocaleString() + ' ' + asset : 'Encrypted';
    document.getElementById('collateral-modal-amount').value = '';
    updateCollateralPreview(0);
    collateralModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeCollateralModal() {
    collateralModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.querySelector('[data-collateral-modal-backdrop]')?.addEventListener('click', closeCollateralModal);
  document.querySelector('[data-collateral-modal-close]')?.addEventListener('click', closeCollateralModal);

  document.getElementById('collateral-modal-amount')?.addEventListener('input', (e) => {
    const val = parseFloat(e.target.value) || 0;
    updateCollateralPreview(val);
  });

  function updateCollateralPreview(amount) {
    const hasAmount = amount > 0;
    ['collateral-ltv', 'collateral-hf'].forEach(p => {
      const arrowEl = document.getElementById(p + '-arrow');
      const newEl = document.getElementById(p + '-new');
      if (arrowEl) arrowEl.classList.toggle('hidden', !hasAmount);
      if (newEl) newEl.classList.toggle('hidden', !hasAmount);
    });

    if (hasAmount) {
      const isAdd = collateralAction === 'add';
      const delta = isAdd ? amount : -amount;
      const newCollateral = Math.max(0, POSITION.totalCollateralUSD + delta * 1);
      const borrowed = POSITION.borrowingUsed;
      const newLTV = newCollateral > 0 ? (borrowed / newCollateral * 100) : 0;
      const newHF = borrowed > 0 ? (newCollateral * POSITION.liquidationThreshold / borrowed) : POSITION.healthFactor;

      const ltvEl = document.getElementById('collateral-ltv-new');
      if (ltvEl) { ltvEl.textContent = newLTV.toFixed(1) + '%'; ltvEl.className = ltvColor(newLTV); }
      const hfEl = document.getElementById('collateral-hf-new');
      if (hfEl) { hfEl.textContent = newHF.toFixed(2); hfEl.className = hfColor(newHF); }
    }
  }

  document.getElementById('collateral-modal-submit')?.addEventListener('click', async function() {
    const amount = document.getElementById('collateral-modal-amount').value;
    if (!amount || parseFloat(amount) <= 0) return;
    const action = collateralAction === 'add' ? 'deposit' : 'withdraw';
    await executeTx(this, action, collateralAssetName, amount, closeCollateralModal);
  });

  async function executeTx(btn, action, asset, amount, onSuccess) {
    if (!window.fhield?.wallet?.isConnected()) {
      window.fhield?.toast?.show('Please connect your wallet first', 'error');
      return;
    }

    const original = btn.innerHTML;
    btn.disabled = true;

    try {
      btn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span><span>Approving...</span>';
      const ci = window.fhield.contracts;

      if (action === 'borrow') await ci.borrow(asset, amount);
      else if (action === 'repay') await ci.repay(asset, amount);
      else if (action === 'deposit') await ci.deposit(asset, amount);
      else if (action === 'withdraw') await ci.withdraw(asset, amount);

      btn.disabled = false;
      btn.innerHTML = original;
      if (onSuccess) onSuccess();
      window.fhield.toast.show(action.charAt(0).toUpperCase() + action.slice(1) + ' of ' + amount + ' ' + asset + ' confirmed!', 'success');
      window.fhield.wallet.loadBalances();
    } catch (err) {
      btn.disabled = false;
      btn.innerHTML = original;
      window.fhield.toast.show(err.reason || err.message || 'Transaction failed', 'error');
    }
  }

  // --- Escape key ---
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeBorrowModal();
      closeManageModal();
      closeCollateralModal();
    }
  });
})();
</script>
