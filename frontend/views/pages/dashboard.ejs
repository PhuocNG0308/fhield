<main>
  <!-- Hero Section -->
  <section class="relative min-h-[720px] flex flex-col justify-center px-6 max-w-7xl mx-auto overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-10 pointer-events-none">
      <div class="w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary via-transparent to-transparent"></div>
    </div>
    <div class="max-w-4xl space-y-8 relative z-10">
      <div class="flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-tertiary-container shield-pulse"></div>
        <span class="font-label text-[0.6875rem] uppercase tracking-[0.2em] text-primary">Fully Homomorphic Encryption</span>
      </div>
      <h1 class="font-headline text-[4rem] md:text-[5.5rem] font-bold leading-[0.9] tracking-tighter text-white">
        Private DeFi <br/>
        <span class="text-primary">Lending &amp; Borrowing</span>
      </h1>
      <p class="max-w-xl text-white/60 font-body text-lg leading-relaxed">
        The monolithic void for your assets. Transact, lend, and borrow with absolute mathematical privacy on the world's most secure shielded layer.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="/lend" class="px-8 py-4 bg-primary text-on-primary font-bold rounded-md hover:scale-[1.02] active:scale-95 transition-all font-headline">
          ENTER THE VAULT
        </a>
        <a href="https://phuocng0308.github.io/fhield/" target="_blank" class="px-8 py-4 border border-outline-variant/15 text-white font-medium rounded-md hover:bg-surface-container transition-all font-headline">
          VIEW DOCUMENTATION
        </a>
      </div>
    </div>
    <div class="absolute bottom-12 right-6 hidden xl:block">
      <div id="cipher-text" class="font-headline text-[8rem] font-extrabold text-surface-container-high/60 select-none cursor-default transition-colors duration-500 hover:text-primary/30" data-target="FHIELD"></div>
    </div>
    <script>
      (function() {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
        const el = document.getElementById('cipher-text');
        if (!el) return;
        const target = el.dataset.target;
        let frame;
        function scramble() {
          let s = '';
          for (let i = 0; i < target.length; i++) s += chars[Math.floor(Math.random() * chars.length)];
          el.textContent = s;
        }
        function idle() { scramble(); frame = setTimeout(idle, 500); }
        idle();
        let step = 0;
        el.addEventListener('mouseenter', function decode() {
          clearTimeout(frame);
          step = 0;
          (function tick() {
            if (step > target.length) return;
            let s = '';
            for (let i = 0; i < target.length; i++) s += i < step ? target[i] : chars[Math.floor(Math.random() * chars.length)];
            el.textContent = s;
            step++;
            frame = setTimeout(tick, 50);
          })();
        });
        el.addEventListener('mouseleave', function() { clearTimeout(frame); idle(); });
      })();
    </script>
  </section>

  <!-- Dashboard Preview Section -->
  <section class="py-24 px-6 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-4 space-y-6">
          <h2 class="font-headline text-4xl font-bold tracking-tight text-white">Institutional Grade Analytics</h2>
          <p class="text-white/50 font-body text-sm leading-relaxed">
            Monitor your shielded position in real-time. Our zero-knowledge proofs ensure you are the only one who sees your data.
          </p>
          <div class="grid grid-cols-2 gap-4 pt-6">
            <div class="p-6 bg-surface-container rounded-lg">
              <span class="block text-[0.625rem] uppercase tracking-widest text-white/40 mb-1">Total Value Locked</span>
              <span class="text-2xl font-headline font-bold text-white" data-fhe-value><%= stats.tvlFmt %></span>
            </div>
            <div class="p-6 bg-surface-container rounded-lg">
              <span class="block text-[0.625rem] uppercase tracking-widest text-white/40 mb-1">Shielded Volume</span>
              <span class="text-2xl font-headline font-bold text-primary" data-fhe-value><%= stats.totalBorrowedFmt %></span>
            </div>
          </div>
        </div>
        <div class="lg:col-span-8 bg-surface-container p-8 rounded-xl relative overflow-hidden">
          <div class="flex justify-between items-center mb-12">
            <div>
              <h3 class="font-headline text-xl font-bold">Asset Performance</h3>
              <p class="text-[0.6875rem] text-white/40 uppercase tracking-widest mt-1">Global Shielded Index</p>
            </div>
            <div class="flex gap-2">
              <span class="px-3 py-1 bg-surface-container-high rounded text-[0.625rem] text-primary">LIVE</span>
              <span class="px-3 py-1 bg-surface-container-high rounded text-[0.625rem] text-white/60">24H</span>
            </div>
          </div>
          <div class="h-64 flex items-end gap-1 px-2 relative">
            <div class="absolute inset-0 flex flex-col justify-between pointer-events-none">
              <div class="w-full border-t border-white/5"></div>
              <div class="w-full border-t border-white/5"></div>
              <div class="w-full border-t border-white/5"></div>
              <div class="w-full border-t border-white/5"></div>
            </div>
            <div class="flex-1 bg-surface-container-highest/50 h-[40%] rounded-t-sm"></div>
            <div class="flex-1 bg-surface-container-highest/50 h-[45%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary/20 h-[55%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary/40 h-[70%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary h-[85%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary/60 h-[75%] rounded-t-sm"></div>
            <div class="flex-1 bg-surface-container-highest/50 h-[60%] rounded-t-sm"></div>
            <div class="flex-1 bg-surface-container-highest/50 h-[50%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary/30 h-[65%] rounded-t-sm"></div>
            <div class="flex-1 bg-primary h-[90%] rounded-t-sm"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Grid -->
  <section class="py-20 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="p-6 bg-surface-container rounded-xl">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[0.625rem] uppercase tracking-widest text-white/40 font-label">TVL</span>
          <span class="material-symbols-outlined text-primary text-xl">account_balance_wallet</span>
        </div>
        <div class="text-3xl font-headline font-bold text-white" data-fhe-value><%= stats.tvlFmt %></div>
        <div class="mt-2 text-[0.6875rem] text-primary font-medium flex items-center gap-1">
          <span class="material-symbols-outlined text-xs">trending_up</span> +2.4% vs last week
        </div>
      </div>
      <div class="p-6 bg-surface-container rounded-xl">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[0.625rem] uppercase tracking-widest text-white/40 font-label">Total Borrowed</span>
          <span class="material-symbols-outlined text-primary text-xl">payments</span>
        </div>
        <div class="text-3xl font-headline font-bold text-white" data-fhe-value><%= stats.totalBorrowedFmt %></div>
        <div class="mt-2 text-[0.6875rem] text-white/40 font-medium"><%= stats.utilization %>% Utilization</div>
      </div>
      <div class="p-6 bg-surface-container rounded-xl">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[0.625rem] uppercase tracking-widest text-white/40 font-label">Active Markets</span>
          <span class="material-symbols-outlined text-primary text-xl">grid_view</span>
        </div>
        <div class="text-3xl font-headline font-bold text-white"><%= stats.activeMarkets %></div>
        <div class="mt-2 text-[0.6875rem] text-white/40 font-medium">Isolated Pools</div>
      </div>
      <div class="p-6 bg-surface-container rounded-xl">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[0.625rem] uppercase tracking-widest text-white/40 font-label">Avg Supply APY</span>
          <span class="material-symbols-outlined text-primary text-xl">show_chart</span>
        </div>
        <div class="text-3xl font-headline font-bold text-white"><%= stats.avgSupplyAPY %>%</div>
        <div class="mt-2 text-[0.6875rem] text-primary font-medium flex items-center gap-1">
          <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">security</span> FHE Secured
        </div>
      </div>
    </div>
  </section>

  <!-- Shielded Markets Section -->
  <section class="py-20 px-6 max-w-7xl mx-auto">
    <div class="mb-16">
      <h2 class="font-headline text-[2.75rem] font-bold tracking-tight mb-4">Shielded Markets</h2>
      <div class="w-24 h-1 bg-primary"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-<%= Math.min(markets.length, 4) %> gap-8">
      <% markets.forEach(function(m, i) { %>
      <div class="group bg-surface-container p-8 rounded-xl transition-all hover:bg-surface-container-high">
        <div class="flex justify-between items-start mb-10">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-[#001623] rounded-full flex items-center justify-center border border-outline-variant/15">
              <img alt="<%= m.name %>" class="w-7 h-7 rounded-full" src="<%= m.img %>" />
            </div>
            <div>
              <h4 class="font-headline text-xl font-bold"><%= m.name %></h4>
              <span class="text-[0.6875rem] text-white/40 uppercase tracking-widest"><%= m.fullName %> Shielded</span>
            </div>
          </div>
          <span class="text-primary font-bold"><%= m.supplyAPY %>% APY</span>
        </div>
        <div class="space-y-4 mb-8">
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Market Size</span>
            <span class="text-white" data-fhe-value><%= m.suppliedFmt %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Total Borrowed</span>
            <span class="text-white" data-fhe-value><%= m.borrowedFmt %></span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-white/40">Utilization</span>
            <span class="text-white"><%= m.utilization %>%</span>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <a href="/lend" class="py-3 bg-primary text-on-primary text-[0.75rem] font-bold rounded uppercase tracking-wider transition-transform active:scale-95 text-center">Supply</a>
          <a href="/borrow" class="py-3 border border-outline-variant/30 text-white text-[0.75rem] font-bold rounded uppercase tracking-wider transition-colors hover:bg-surface-container-highest text-center">Borrow</a>
        </div>
      </div>
      <% }) %>
    </div>
  </section>

  <!-- Security & Privacy Section -->
  <section class="py-20 px-6 bg-surface-container-low">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 p-10 bg-surface-container rounded-xl">
        <h3 class="text-[1.75rem] font-headline font-bold text-white mb-8">Security &amp; Privacy Stack</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 border border-primary/20">
              <span class="material-symbols-outlined text-primary">data_object</span>
            </div>
            <div>
              <h4 class="font-headline font-bold text-white mb-1">Fully Homomorphic Encryption</h4>
              <p class="text-sm text-white/50 leading-relaxed">Perform operations on encrypted data without ever decrypting it, ensuring total state privacy.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0 border border-primary/20">
              <span class="material-symbols-outlined text-primary">lock_reset</span>
            </div>
            <div>
              <h4 class="font-headline font-bold text-white mb-1">On-Chain Privacy</h4>
              <p class="text-sm text-white/50 leading-relaxed">Asset balances and borrow amounts remain obscured from the public mempool and blockchain explorers.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="p-10 bg-surface-container rounded-xl flex flex-col justify-center items-center text-center">
        <div class="w-20 h-20 bg-[#001623] rounded-full flex items-center justify-center mb-6 border border-outline-variant/15">
          <span class="material-symbols-outlined text-4xl text-primary" style="font-variation-settings: 'FILL' 1;">shield_with_heart</span>
        </div>
        <h3 class="text-lg font-headline font-bold text-white mb-2">Protocol Health</h3>
        <p class="text-sm text-white/50 mb-6">Operating at full capacity with all privacy layers verified.</p>
        <button class="w-full py-3 border border-outline-variant/30 text-white text-[0.75rem] font-bold rounded uppercase tracking-wider transition-colors hover:bg-surface-container-highest">Check Audits</button>
      </div>
    </div>
  </section>
</main>
