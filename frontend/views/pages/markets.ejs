<main class="layout-main with-sidebar max-w-screen-2xl mx-auto">
  <section class="mb-12 relative overflow-hidden rounded-2xl bg-surface-container-lowest border border-outline-variant/10 px-8 py-6">
    <div class="absolute top-0 right-0 w-1/3 h-full opacity-[0.07] pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-l from-primary to-transparent"></div>
    </div>
    <div class="absolute bottom-0 left-0 w-40 h-40 bg-tertiary/5 rounded-full blur-[80px] -mb-20 -ml-20 pointer-events-none"></div>
    <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="flex items-center gap-5">
        <div class="relative w-16 h-16 rounded-full bg-gradient-to-br from-[#2775ca] to-[#f5f5f5] p-0.5 shadow-[0_0_24px_rgba(39,117,202,0.2)]">
          <div class="w-full h-full rounded-full bg-surface-container flex items-center justify-center overflow-hidden">
            <img alt="<%= market.name %>" class="w-11 h-11" src="<%= market.img %>" />
          </div>
          <div class="absolute -bottom-0.5 -right-0.5 bg-tertiary p-1 rounded-full border-[3px] border-surface-container-lowest">
            <span class="material-symbols-outlined text-[14px] text-on-tertiary-container font-bold">verified_user</span>
          </div>
        </div>
        <div>
          <span class="badge badge-primary mb-1.5">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">encrypted</span>
            FHE Enabled
          </span>
          <h1 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tight text-on-surface"><%= market.fullName %> <span class="text-primary-container">(<%= market.name %>)</span></h1>
        </div>
      </div>
      <div class="flex gap-3">
        <button class="btn-secondary px-6 py-2.5 rounded-xl text-sm">Details</button>
        <a href="/deposit?asset=<%= market.name %>" class="btn-primary px-7 py-2.5 rounded-xl text-sm shadow-[0_4px_20px_rgba(76,215,246,0.2)] inline-block">Supply Assets</a>
      </div>
    </div>
  </section>

  <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
    <div class="xl:col-span-7 space-y-8">
      <section class="glass-panel rounded-2xl p-8 overflow-hidden relative border border-outline-variant/10">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        <h2 class="text-sm font-label font-bold text-outline tracking-widest uppercase mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-lg">account_balance</span>
          Supply Statistics
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Total Supply</p><p class="text-2xl font-headline font-bold text-on-surface"><%= market.suppliedFmt %></p></div>
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Supply APY</p><p class="text-2xl font-headline font-bold text-primary"><%= market.supplyAPY %>%</p></div>
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Liquidity Index</p><p class="text-2xl font-headline font-bold text-on-surface">1.02x</p></div>
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Reserve Factor</p><p class="text-2xl font-headline font-bold text-on-surface">10%</p></div>
        </div>
      </section>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        <div class="md:col-span-2 glass-panel rounded-2xl p-8 border border-outline-variant/10 flex flex-col items-center justify-center text-center">
          <h3 class="text-xs font-label font-bold text-outline tracking-widest uppercase mb-6">Utilization</h3>
          <div class="relative w-40 h-40 flex items-center justify-center">
            <svg class="w-full h-full -rotate-90">
              <circle class="text-surface-container-highest" cx="80" cy="80" fill="transparent" r="68" stroke="currentColor" stroke-width="12"></circle>
              <circle class="text-primary utilization-ring" cx="80" cy="80" fill="transparent" r="68" stroke="currentColor" stroke-linecap="round" stroke-width="12"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-3xl font-headline font-extrabold text-on-surface"><%= market.utilization %>%</span>
              <span class="text-[10px] text-outline font-bold uppercase">Optimal</span>
            </div>
          </div>
          <p class="mt-6 text-xs text-on-surface-variant leading-relaxed">System health is stable within the target safety threshold.</p>
        </div>
        <div class="md:col-span-3 glass-panel rounded-2xl p-8 border border-outline-variant/10">
          <h3 class="text-xs font-label font-bold text-outline tracking-widest uppercase mb-6">Interest Rate Model</h3>
          <div class="h-48 w-full relative chart-grid border-l border-b border-outline-variant/20">
            <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
              <path d="M 0 90 L 80 50 L 100 10" fill="none" stroke="#4cd7f6" stroke-width="2" vector-effect="non-scaling-stroke"></path>
              <circle cx="80" cy="50" fill="#06b6d4" r="4"></circle>
            </svg>
            <div class="absolute left-[80%] bottom-[50%] transform -translate-x-1/2 -translate-y-4">
              <span class="bg-primary text-on-primary-fixed text-[8px] font-bold px-1.5 py-0.5 rounded uppercase">Kink: 80%</span>
            </div>
          </div>
          <div class="mt-6 grid grid-cols-3 gap-2">
            <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary/40"></span><span class="text-[10px] text-on-surface-variant font-medium">Base: 0%</span></div>
            <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary/70"></span><span class="text-[10px] text-on-surface-variant font-medium">Slope 1: 4%</span></div>
            <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary"></span><span class="text-[10px] text-on-surface-variant font-medium">Slope 2: 75%</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="xl:col-span-5 space-y-8">
      <section class="bg-surface-container rounded-2xl p-8 border border-outline-variant/10 relative overflow-hidden">
        <div class="flex justify-between items-start mb-6">
          <h2 class="text-sm font-label font-bold text-outline tracking-widest uppercase flex items-center gap-2">
            <span class="material-symbols-outlined text-tertiary text-lg">trending_up</span>
            Borrow Statistics
          </h2>
          <span class="text-[10px] text-outline font-medium px-2 py-1 bg-surface-container-high rounded-lg">Updated 2m ago</span>
        </div>
        <div class="grid grid-cols-2 gap-y-6">
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Total Borrowed</p><p class="text-2xl font-headline font-bold text-on-surface"><%= market.borrowedFmt %></p></div>
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Borrow APY</p><p class="text-2xl font-headline font-bold text-tertiary"><%= market.borrowAPY %>%</p></div>
          <div class="space-y-1"><p class="text-xs text-on-surface-variant font-medium">Borrow Index</p><p class="text-xl font-headline font-bold text-on-surface">1.05x</p></div>
          <div class="space-y-1">
            <p class="text-[10px] text-on-surface-variant font-bold uppercase tracking-widest">Reserve Capacity</p>
            <div class="w-full bg-surface-container-highest h-2 rounded-full mt-2"><div class="bg-tertiary h-full rounded-full" data-width="<%= market.utilization %>"></div></div>
          </div>
        </div>
      </section>

      <section class="bg-surface-container-low border border-outline-variant/5 rounded-2xl p-8">
        <h3 class="text-xs font-label font-bold text-outline tracking-widest uppercase mb-6">Asset Configuration</h3>
        <div class="space-y-4">
          <div class="flex justify-between items-center py-2 border-b border-outline-variant/5"><span class="text-sm text-on-surface-variant">LTV (Loan-to-Value)</span><span class="text-sm font-bold text-on-surface">80%</span></div>
          <div class="flex justify-between items-center py-2 border-b border-outline-variant/5"><span class="text-sm text-on-surface-variant">Liquidation Threshold</span><span class="text-sm font-bold text-on-surface">85%</span></div>
          <div class="flex justify-between items-center py-2 border-b border-outline-variant/5"><span class="text-sm text-on-surface-variant">Liquidation Bonus</span><span class="text-sm font-bold text-primary">5%</span></div>
          <div class="flex justify-between items-center py-2"><span class="text-sm text-on-surface-variant">Decimals</span><span class="text-sm font-bold text-on-surface"><%= market.decimals %></span></div>
        </div>
      </section>

      <section class="glass-panel border-2 border-primary/20 rounded-2xl p-8 shadow-[0_0_50px_rgba(6,182,212,0.1)]" data-requires-wallet>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">enhanced_encryption</span>
          </div>
          <div>
            <h3 class="text-lg font-headline font-bold text-on-surface">FHE Wrapper</h3>
            <p class="text-xs text-on-surface-variant">Encrypt your <%= market.name %> for private lending</p>
          </div>
        </div>
        <div class="bg-surface-container-highest rounded-xl p-4 mb-4 border border-outline-variant/20 focus-within:border-primary/50 transition-all">
          <label class="block text-[10px] font-bold text-outline uppercase tracking-wider mb-2">Amount to Process</label>
          <div class="flex items-center justify-between">
            <input class="bg-transparent border-none focus:ring-0 text-xl font-headline font-bold text-on-surface w-full" placeholder="0.00" type="number" />
            <span class="text-sm font-bold text-on-surface-variant ml-2"><%= market.name %></span>
          </div>
        </div>
        <div class="flex gap-3 mb-6">
          <button data-action-btn="Wrap" class="flex-1 btn-primary py-3 rounded-xl text-sm">Wrap</button>
          <button data-action-btn="Unwrap" class="flex-1 btn-secondary py-3 rounded-xl text-sm">Unwrap</button>
        </div>
        <div class="flex justify-between items-center bg-primary/5 p-4 rounded-xl border border-primary/10">
          <span class="text-xs text-on-surface-variant font-medium">Current Privacy Balance:</span>
          <div class="text-right">
            <p class="text-sm font-headline font-extrabold text-primary">1,250.00 f<%= market.name %></p>
            <p class="text-[10px] text-outline italic">Encrypted Layer 2</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</main>
