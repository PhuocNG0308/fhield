<header class="bg-[#001623] sticky top-0 z-50">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
    <a href="/" class="flex items-center gap-2">
      <img src="/img/fhield-icon.png" alt="Fhield" class="h-8 w-8" />
      <span class="text-3xl font-bold tracking-tighter text-white font-headline">FHIELD</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <% navItems.forEach(function(item) { %>
        <a class="font-headline uppercase tracking-[0.05em] text-[0.8125rem] transition-colors duration-300 <%= activePage === item.key ? 'text-primary font-bold' : 'text-white/70 hover:text-primary' %>" href="<%= item.href %>"><%= item.label %></a>
      <% }) %>
    </nav>
    <div class="flex items-center gap-3">
      <button data-fhe-toggle class="p-2 text-white/70 hover:text-primary transition-colors" title="Toggle encrypted data visibility">
        <span class="material-symbols-outlined">visibility</span>
      </button>
      <div class="relative" id="wallet-container">
        <button data-connect-wallet class="hidden lg:flex items-center gap-2 px-4 py-2 bg-surface-container rounded hover:bg-surface-container-high transition-colors text-[0.75rem] font-medium tracking-tight text-white">
          <span class="material-symbols-outlined text-[18px]">account_balance_wallet</span>
          <span data-wallet-label>Connect Wallet</span>
        </button>
        <div id="wallet-dropdown" class="hidden absolute right-0 top-full mt-2 w-64 glass-panel rounded-xl border border-outline-variant/10 overflow-hidden shadow-lg z-50">
          <div class="p-4">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-2.5 h-2.5 bg-green-400 rounded-full shrink-0 animate-pulse"></div>
              <span class="text-sm font-bold text-on-surface truncate" data-wallet-address></span>
            </div>
            <div class="text-xs text-on-surface-variant">Arbitrum Sepolia</div>
          </div>
          <div class="border-t border-outline-variant/10">
            <button data-disconnect-wallet class="w-full flex items-center gap-2 px-4 py-3 text-sm text-red-400 hover:bg-red-400/5 transition-colors">
              <span class="material-symbols-outlined text-[18px]">logout</span>
              Disconnect
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
